{
  "buildCommand": null,
  "outputDirectory": ".",
  "framework": null,
  "cleanUrls": true,
  "trailingSlash": false,
  "ignoreCommand": "git diff HEAD^ HEAD --quiet -- pattamansa/",
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "www.pattamansa.com.br" }],
      "destination": "https://pattamansa.com.br/$1",
      "permanent": true
    }
  ]
}
