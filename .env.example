# MotorIA Risk Engine™ — variáveis de ambiente
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commite o .env com valores reais no repositório.

# ── Supabase ──────────────────────────────────────────────────────────────────
# Crie um projeto em supabase.com → Settings → API
# VITE_ prefix = acessível no browser (seguro para anon key)
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...
# Service role key — NÃO exponha no frontend. Usada apenas em Vercel functions.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Kiwify Webhook ─────────────────────────────────────────────────────────────
# Gerada por você. Configure também no painel Kiwify:
# Produto → Webhooks → URL: https://motoriaopro.com.br/api/webhook/payment
KIWIFY_WEBHOOK_SECRET=gere-uma-string-longa-e-aleatoria-aqui

# ── IA ─────────────────────────────────────────────────────────────────────────
# Chave da API Anthropic (console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# ── Redis (Upstash) ────────────────────────────────────────────────────────────
# Banco de dados para tokens, créditos e rate limiting.
# Crie um banco gratuito em upstash.com → Redis → REST API
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxxxx

# ── Email (Resend) ─────────────────────────────────────────────────────────────
# Serviço de email transacional para enviar o acesso pós-compra.
# Crie uma conta gratuita em resend.com → API Keys
# IMPORTANTE: configure e verifique o domínio remetente no painel do Resend.
RESEND_API_KEY=re_...
RESEND_FROM=MotorIA <acesso@motoriaopro.com.br>

# ── App ────────────────────────────────────────────────────────────────────────
# URL base do app (sem barra final). Usada nos links do email de acesso.
APP_URL=https://motoriaopro.com.br

# ── Kiwify Webhook ─────────────────────────────────────────────────────────────
# Segredo para autenticar webhooks da Kiwify.
# Gere uma string aleatória longa e configure TAMBÉM no painel da Kiwify:
#   Produto → Configurações → Webhooks → URL:
#   https://motoriaopro.com.br/api/webhook-kiwify?token=SEU_WEBHOOK_SECRET
WEBHOOK_SECRET=gere-uma-string-longa-e-aleatoria-aqui

# ── Admin ──────────────────────────────────────────────────────────────────────
# Segredo para gerar tokens manualmente via /api/admin-generate
# Uso: curl -X POST https://.../api/admin-generate \
#        -H "Authorization: Bearer SEU_ADMIN_SECRET" \
#        -H "Content-Type: application/json" \
#        -d '{"email":"cliente@exemplo.com"}'
ADMIN_SECRET=gere-outra-string-longa-e-aleatoria-aqui

# ── CORS ───────────────────────────────────────────────────────────────────────
# Origem permitida para chamadas à API (seu domínio de produção)
ALLOWED_ORIGIN=https://motoriaopro.com.br

# ── Jogos de Hoje ──────────────────────────────────────────────────────────────
# Fonte de dados: ESPN Scoreboard API (pública, sem chave necessária)
# Cobre: Brasileirão, Série B, Copa do Brasil, Premier League, La Liga,
#        Bundesliga, Serie A, Ligue 1, Champions League, Libertadores, Sul-Americana
# Não é necessário configurar nada — funciona automaticamente.
